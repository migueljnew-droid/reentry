{
  "expo": {
    "name": "REENTRY",
    "slug": "reentry",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "reentry",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#172b54"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "org.fatherscan.reentry",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "REENTRY uses your microphone for voice-first intake. You can speak your answers instead of typing."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#172b54"
      },
      "package": "org.fatherscan.reentry",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2577eb"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "reentry"
      }
    }
  }
}
